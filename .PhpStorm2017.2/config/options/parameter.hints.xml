<application>
  <component name="ParameterNameHintsSettings">
    <blacklists>
      <blacklist language="PHP">
        <added pattern="\compact(varname,_)" />
        <added pattern="\Illuminate\Routing\Redirector.action(action,parameters,status,headers)" />
        <added pattern="\abort(code,message,headers)" />
        <added pattern="\log_append(path,message)" />
        <added pattern="\Illuminate\Contracts\Container\Container.singleton(abstract,concrete)" />
        <added pattern="\Carbon\Carbon.addWeek(value)" />
        <added pattern="\Carbon\Carbon.addMonth(value)" />
        <added pattern="\array_fill_keys(keys,value)" />
        <added pattern="\Carbon\Carbon.addDay(value)" />
        <added pattern="\Illuminate\Database\Eloquent\Builder.where(column,operator,value,boolean)" />
        <added pattern="\Illuminate\Routing\Router.model(key,class,callback)" />
        <removed pattern="" />
      </blacklist>
    </blacklists>
  </component>
</application>